# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/tests/e2e/browser/screenshots/

# next.js
/.next/
/out/

# production
/build
/native/keychain-helper/.build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# Allow encrypted env file to be committed (keys file must never be committed)
!.env.tianjin
!.env.local.example

# playwright MCP logs
.playwright-mcp/

# debug/one-off scripts
scripts/fast-sync.ts
scripts/test-railgun-unshield.ts
scripts/quick-unshield-test.ts
scripts/benchmark-local-models.ts

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
