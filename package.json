{
  "name": "private-ethereum-assistant",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "local": "bun run scripts/local.ts",
    "build": "next build",
    "start": "next start",
    "lint": "bunx eslint .",
    "test": "bun test src",
    "test:e2e:tools": "bun run scripts/run-bun-test-glob.ts --timeout 120000 --max-concurrency 1 'tests/e2e/tools/*.e2e.ts'",
    "test:e2e:llm": "bun run scripts/run-bun-test-glob.ts --timeout 120000 'tests/e2e/llm/*.e2e.ts'",
    "test:e2e:browser": "bun run tests/e2e/browser/run-browser-tests.ts"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@ai-sdk/react": "^3.0.118",
    "@base-ui/react": "^1.2.0",
    "@cowprotocol/cow-sdk": "^8.0.0",
    "@cowprotocol/sdk-viem-adapter": "^0.3.11",
    "@railgun-community/engine": "^9.5.3",
    "@railgun-community/shared-models": "^8.0.1",
    "@railgun-community/wallet": "^10.8.4",
    "@safe-global/api-kit": "^4.0.1",
    "@safe-global/protocol-kit": "^6.1.2",
    "@safe-global/types-kit": "^3.0.0",
    "ai": "^6.0.116",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.35.1",
    "leveldown": "^6.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "shadcn": "^4.0.2",
    "snarkjs": "^0.7.6",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.3",
    "viem": "^2.47.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-types": "^1.3.10",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "5.9.3"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
